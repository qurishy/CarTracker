@{
    ViewData["Title"] = "Vehicle Tracker";
    int? carId = ViewBag.CarId;
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <style>
        #map {
            height: 85vh;
            border-radius: 8px;
            min-height: 600px;
        }

        .car-marker {
            filter: hue-rotate(200deg);
            width: 32px !important;
            height: 32px !important;
            z-index: 1000;
        }

        .car-marker-realtime {
            animation: pulse 2s infinite;
        }

        @@keyframes pulse {
            0%

        {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.1);
            opacity: 0.8;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }

        }

        .history-line {
            color: #6c757d;
            weight: 3;
            opacity: 0.6;
        }

        .realtime-line {
            color: #dc3545;
            weight: 4;
            dashArray: '8,4';
        }

        .route-line {
            color: #0d6efd;
            weight: 5;
            opacity: 0.8;
            dashArray: '10,5';
        }

        .saved-route-line {
            color: #198754;
            weight: 4;
            opacity: 0.8;
            dashArray: '8,4';
        }

        .connection-status {
            position: absolute;
            top: 15px;
            left: 15px;
            z-index: 1000;
            padding: 8px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .connection-connected {
            background: rgba(25, 135, 84, 0.9);
            color: white;
        }

        .connection-disconnected {
            background: rgba(220, 53, 69, 0.9);
            color: white;
        }

        .connection-connecting {
            background: rgba(255, 193, 7, 0.9);
            color: black;
        }

        #routeControls {
            position: absolute;
            top: 15px;
            right: 15px;
            z-index: 1000;
            background: white;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            min-width: 320px;
            max-width: 400px;
        }

        .route-controls-header {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            margin: -20px -20px 20px -20px;
            padding: 15px 20px;
            border-radius: 12px 12px 0 0;
            color: white;
        }

        .card {
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
            border: none;
        }

        .route-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
        }

        .saved-route-card {
            transition: all 0.3s ease;
            cursor: pointer;
            border-left: 4px solid #198754;
        }

            .saved-route-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 25px rgba(0,0,0,0.15);
                border-left-color: #0d6efd;
            }

        .real-time-indicator {
            display: inline-block;
            width: 8px;
            height: 8px;
            background: #28a745;
            border-radius: 50%;
            animation: blink 1.5s infinite;
            margin-right: 6px;
        }

        @@keyframes blink {
            0%, 50%

        {
            opacity: 1;
        }

        51%, 100% {
            opacity: 0.3;
        }

        }

        .alert-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
            max-width: 400px;
        }

        .stats-card {
            background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        }

        .speed-indicator {
            font-size: 1.2rem;
            font-weight: bold;
            color: #0d6efd;
        }

        .distance-traveled {
            font-size: 0.9rem;
            color: #6c757d;
        }

        .waypoint-marker {
            background: #fff;
            border: 2px solid #0d6efd;
            border-radius: 50%;
            width: 20px;
            height: 20px;
        }

        .destination-marker {
            color: #dc3545;
        }

        .start-marker {
            color: #198754;
        }

        .scroll-container {
            max-height: 300px;
            overflow-y: auto;
        }

            .scroll-container::-webkit-scrollbar {
                width: 6px;
            }

            .scroll-container::-webkit-scrollbar-track {
                background: #f1f1f1;
                border-radius: 3px;
            }

            .scroll-container::-webkit-scrollbar-thumb {
                background: #c1c1c1;
                border-radius: 3px;
            }

                .scroll-container::-webkit-scrollbar-thumb:hover {
                    background: #a8a8a8;
                }
    </style>
</head>
<body>
    <div class="container-fluid p-0">
        <div class="row g-0">
            <!-- Car Details Sidebar -->
            <div class="col-md-4 col-lg-3 bg-light border-end" style="height: 100vh; overflow-y: auto;">
                <div class="p-3">
                    <!-- Vehicle Status Card -->
                    <div class="card mb-3">
                        <div class="card-header bg-primary text-white d-flex align-items-center">
                            <i class="fas fa-car me-2"></i>
                            <h6 class="mb-0" id="carHeader">Vehicle Details</h6>
                        </div>
                        <div class="card-body" id="carDetails">
                            @if (carId.HasValue)
                            {
                                <div class="text-center py-4">
                                    <div class="spinner-border text-primary" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p class="mt-2 mb-0">Loading vehicle data...</p>
                                </div>
                            }
                            else
                            {
                                <div class="text-center py-4">
                                    <i class="fas fa-exclamation-triangle text-warning fa-2x mb-3"></i>
                                    <p class="text-muted mb-0">No vehicle selected. Please select a vehicle from the dashboard.</p>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Real-time Statistics -->
                    <div class="card mb-3 stats-card" id="realTimeStats" style="display: none;">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <span class="real-time-indicator"></span>
                                Live Statistics
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="row g-2">
                                <div class="col-6">
                                    <div class="text-center">
                                        <div class="speed-indicator" id="currentSpeed">0</div>
                                        <small class="text-muted">km/h</small>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="text-center">
                                        <div class="speed-indicator" id="totalDistance">0.0</div>
                                        <small class="text-muted">km today</small>
                                    </div>
                                </div>
                            </div>
                            <hr>
                            <div class="row g-2">
                                <div class="col-6">
                                    <small class="text-muted">Last Update:</small>
                                    <div class="fw-bold" id="lastUpdate">-</div>
                                </div>
                                <div class="col-6">
                                    <small class="text-muted">Status:</small>
                                    <div class="fw-bold text-success" id="vehicleStatus">Active</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Current Route Display -->
                    <div class="card mb-3" id="currentRouteCard" style="display: none;">
                        <div class="card-header route-card">
                            <h6 class="mb-0">
                                <i class="fas fa-route me-2"></i>Active Route
                            </h6>
                        </div>
                        <div class="card-body" id="currentRouteDetails">
                            <!-- Current route details will be populated here -->
                        </div>
                    </div>

                    <!-- Route Planning Controls -->
                    <div class="card mb-3">
                        <div class="card-header bg-info text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-map-marked-alt me-2"></i>Route Planning
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="input-group mb-3">
                                <span class="input-group-text"><i class="fas fa-search"></i></span>
                                <input type="text" id="destination" class="form-control" placeholder="Search destination..." list="destinationSuggestions">
                                <datalist id="destinationSuggestions"></datalist>
                            </div>
                            <div class="d-grid gap-2">
                                <button id="findRouteBtn" class="btn btn-primary">
                                    <i class="fas fa-route me-1"></i>Find Route
                                </button>
                                <div class="btn-group" role="group">
                                    <button id="saveRouteBtn" class="btn btn-success btn-sm" style="display: none;">
                                        <i class="fas fa-save me-1"></i>Save
                                    </button>
                                    <button id="clearRouteBtn" class="btn btn-outline-danger btn-sm">
                                        <i class="fas fa-times me-1"></i>Clear
                                    </button>
                                </div>
                            </div>
                            <div id="routeInfo" class="mt-3" style="display: none;"></div>
                        </div>
                    </div>

                    <!-- Saved Routes -->
                    <div class="card">
                        <div class="card-header bg-success text-white">
                            <h6 class="mb-0">
                                <i class="fas fa-bookmark me-2"></i>Saved Routes
                            </h6>
                        </div>
                        <div class="card-body p-2">
                            <div id="savedRoutesList" class="scroll-container">
                                <div class="text-center py-3">
                                    <div class="spinner-border spinner-border-sm text-success" role="status"></div>
                                    <p class="small text-muted mt-2 mb-0">Loading routes...</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Map Container -->
            <div class="col-md-8 col-lg-9 position-relative">
                <!-- Connection Status -->
                <div id="connectionStatus" class="connection-status connection-connecting">
                    <i class="fas fa-wifi me-2"></i>Connecting...
                </div>

                <!-- Map -->
                <div id="map"></div>
            </div>
        </div>
    </div>

    <!-- Alert Container -->
    <div id="alertContainer" class="alert-container"></div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@7.0.5/dist/browser/signalr.min.js"></script>

    <script>
        // Global variables
        let map, carMarker, historyPolyline, realtimePolyline, routeLine;
        let currentCarId = @(carId.HasValue? carId.Value: 0);
        let signalRConnection;
        let currentRouteData = null;
        let savedRoutes = [];
        let lastPosition = null;
        let totalDistanceToday = 0;
        let realtimePositions = [];

        // Statistics tracking
        let lastPositionTime = null;
        let currentSpeed = 0;

        $(document).ready(function () {
            console.log('Initializing vehicle tracker for car ID:', currentCarId);

            if (currentCarId > 0) {
                initializeMap();
                setupRouting();
                fetchCarDetails();
                loadSavedRoutes();
                initializeSignalRConnection();
                startPeriodicUpdates();
            } else {
                showAlert('warning', 'No vehicle selected. Please select a vehicle from the dashboard.');
            }
        });

        // Initialize Leaflet map
        function initializeMap() {
            map = L.map('map', {
                center: [34.5553, 69.2075], // Kabul, Afghanistan
                zoom: 13,
                zoomControl: true,
                preferCanvas: true
            });

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors',
                maxZoom: 18,
                tileSize: 256
            }).addTo(map);

            // Add scale control
            L.control.scale({
                position: 'bottomleft',
                metric: true,
                imperial: false
            }).addTo(map);
        }

        // Setup routing functionality
        function setupRouting() {
            const destinationInput = document.getElementById('destination');

            if (destinationInput) {
                let searchTimeout;
                destinationInput.addEventListener('input', function () {
                    clearTimeout(searchTimeout);
                    searchTimeout = setTimeout(() => {
                        if (this.value && this.value.length >= 3) {
                            fetchSuggestions(this.value, 'destinationSuggestions');
                        }
                    }, 300);
                });

                $('#findRouteBtn').click(getRoute);
                $('#saveRouteBtn').click(saveCurrentRoute);
                $('#clearRouteBtn').click(clearRoute);

                // Enter key support
                destinationInput.addEventListener('keypress', function(e) {
                    if (e.key === 'Enter') {
                        e.preventDefault();
                        getRoute();
                    }
                });
            }
        }

        // Fetch car details from server
        async function fetchCarDetails() {
            try {
                updateConnectionStatus('connecting', 'Loading vehicle data...');

                const response = await fetch(`/Map/GetCar?id=${currentCarId}`);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const car = await response.json();
                renderCarDetails(car);
                await fetchCarLocations();

                $('#realTimeStats').show();
                updateConnectionStatus('connected', 'Connected');
            } catch (error) {
                console.error('Failed to load car details:', error);
                $('#carDetails').html(`
                    <div class="alert alert-danger">
                        <i class="fas fa-exclamation-circle me-2"></i>
                        <strong>Error:</strong> ${error.message}
                    </div>
                `);
                updateConnectionStatus('disconnected', 'Failed to load data');
            }
        }

        // Render car details in panel
        function renderCarDetails(car) {
            const lastPos = car.lastPosition || {};
            const isActive = car.lastTracked && new Date(car.lastTracked) > new Date(Date.now() - 3600000); // 1 hour

            const detailsHtml = `
                <div class="text-center mb-3">
                    <i class="fas fa-car fa-2x text-primary mb-2"></i>
                    <h5 class="mb-0">${car.make} ${car.model}</h5>
                    <div class="badge ${isActive ? 'bg-success' : 'bg-warning'} mb-2">
                        ${isActive ? 'Active' : 'Inactive'}
                    </div>
                </div>

                <div class="row g-2 mb-3">
                    <div class="col-6">
                        <div class="text-center p-2 bg-light rounded">
                            <small class="text-muted d-block">License Plate</small>
                            <strong>${car.licensePlate}</strong>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="text-center p-2 bg-light rounded">
                            <small class="text-muted d-block">Total Points</small>
                            <strong>${car.totalLocations || 0}</strong>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="row g-2">
                        <div class="col-12">
                            <small class="text-muted">Current Location:</small>
                            <div class="fw-bold" id="currentLocation">
                                ${lastPos.latitude ? `${lastPos.latitude.toFixed(6)}, ${lastPos.longitude.toFixed(6)}` : 'Unknown'}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <small class="text-muted">Last Tracked:</small>
                    <div class="fw-bold" id="lastTrackedTime">
                        ${car.lastTracked ? new Date(car.lastTracked).toLocaleString() : 'Never'}
                    </div>
                </div>

                <hr>
                <div class="d-grid gap-2">
                    <button class="btn btn-outline-primary btn-sm" onclick="centerMapOnVehicle()">
                        <i class="fas fa-crosshairs me-1"></i>Center on Vehicle
                    </button>
                    <button class="btn btn-outline-info btn-sm" onclick="toggleLocationHistory()">
                        <i class="fas fa-history me-1"></i>Toggle History
                    </button>
                </div>
            `;

            $('#carDetails').html(detailsHtml);
            $('#carHeader').text(`${car.licensePlate} - ${car.make} ${car.model}`);

            // Store last position for tracking
            if (lastPos.latitude && lastPos.longitude) {
                lastPosition = {
                    lat: lastPos.latitude,
                    lng: lastPos.longitude,
                    timestamp: new Date(lastPos.timestamp || car.lastTracked)
                };
            }
        }

        // Fetch location history
        async function fetchCarLocations() {
            try {
                const response = await fetch(`/Map/GetCarLocations?vehicleId=${currentCarId}`);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const locations = await response.json();
                plotLocationHistory(locations);
            } catch (error) {
                console.error('Error loading location history:', error);
                showAlert('warning', `Failed to load travel history: ${error.message}`);
            }
        }

        // Plot location history on map
        function plotLocationHistory(locations) {
            // Clear existing layers
            if (historyPolyline) map.removeLayer(historyPolyline);
            if (realtimePolyline) map.removeLayer(realtimePolyline);
            if (carMarker) map.removeLayer(carMarker);

            if (!locations || locations.length === 0) {
                showAlert('info', 'No location history available for this vehicle');
                return;
            }

            // Convert to LatLng objects and reverse order (oldest first)
            const points = locations.reverse().map(loc => [loc.latitude, loc.longitude]);

            // Create history polyline (gray, older data)
            if (points.length > 1) {
                historyPolyline = L.polyline(points, {
                    color: '#6c757d',
                    weight: 3,
                    opacity: 0.6
                }).addTo(map);

                // Add popup with route info
                historyPolyline.bindPopup(`
                    <b>Travel History</b><br>
                    Points: ${points.length}<br>
                    Period: Last recorded positions
                `);
            }

            // Create marker for latest position
            if (points.length > 0) {
                const lastPoint = points[points.length - 1];
                createCarMarker(lastPoint);

                // Center map on vehicle with appropriate zoom
                map.setView(lastPoint, 15);

                // Create empty real-time polyline
                realtimePolyline = L.polyline([], {
                    color: '#dc3545',
                    weight: 4,
                    dashArray: '8,4'
                }).addTo(map);

                // Calculate total distance for today
                calculateDailyDistance(locations);
            }
        }

        // Create or update car marker
        function createCarMarker(position, isRealtime = false) {
            if (carMarker) {
                map.removeLayer(carMarker);
            }

            const markerClass = isRealtime ? 'car-marker car-marker-realtime' : 'car-marker';

            carMarker = L.marker(position, {
                icon: L.divIcon({
                    className: markerClass,
                    html: '<i class="fa-solid fa-car fa-2x text-primary"></i>',
                    iconSize: [32, 32],
                    iconAnchor: [16, 16]
                }),
                zIndexOffset: 1000
            }).addTo(map);

            // Add popup with current info
            carMarker.bindPopup(`
                <b>Current Position</b><br>
                Coordinates: ${position[0].toFixed(6)}, ${position[1].toFixed(6)}<br>
                Speed: ${currentSpeed.toFixed(1)} km/h<br>
                Last Update: ${new Date().toLocaleTimeString()}
            `);
        }

        // Initialize SignalR connection
        function initializeSignalRConnection() {
            if (typeof signalR === 'undefined') {
                console.log("Waiting for SignalR library to load...");
                setTimeout(initializeSignalRConnection, 1000);
                return;
            }

            console.log("Initializing SignalR connection...");
            updateConnectionStatus('connecting', 'Connecting to real-time service...');

            signalRConnection = new signalR.HubConnectionBuilder()
                .withUrl("/trackingHub")
                .configureLogging(signalR.LogLevel.Information)
                .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                .build();

            // Setup event handlers
            setupSignalRHandlers();

            // Start connection
            signalRConnection.start()
                .then(() => {
                    console.log("SignalR connected. Subscribing to car updates...");
                    updateConnectionStatus('connected', 'Real-time tracking active');
                    return signalRConnection.invoke("SubscribeToCars", [currentCarId]);
                })
                .then(() => {
                    console.log("Successfully subscribed to car updates");
                    showAlert('success', 'Real-time tracking activated');
                })
                .catch(err => {
                    console.error("SignalR connection error:", err);
                    updateConnectionStatus('disconnected', 'Connection failed');
                    showAlert('danger', 'Failed to connect to real-time service');
                    setTimeout(initializeSignalRConnection, 5000);
                });
        }

        // Setup SignalR event handlers
        function setupSignalRHandlers() {
            // Handle single car position updates
            signalRConnection.on("CarPositionUpdate", (position) => {
                console.log("Received position update:", position);
                if (position.carId === currentCarId) {
                    updateCarPosition(position.latitude, position.longitude, position.timestamp);
                }
            });

            // Handle multiple car positions
            signalRConnection.on("MultipleCarPositions", (positions) => {
                console.log("Received multiple positions:", positions.length);
                const carPosition = positions.find(p => p.carId === currentCarId);
                if (carPosition) {
                    updateCarPosition(carPosition.latitude, carPosition.longitude, carPosition.timestamp);
                }
            });

            // Handle initial positions
            signalRConnection.on("InitialPositions", (positions) => {
                console.log("Received initial positions:", positions.length);
                const carPosition = positions.find(p => p.carId === currentCarId);
                if (carPosition) {
                    updateCarPosition(carPosition.latitude, carPosition.longitude, carPosition.timestamp);
                }
            });

            // Connection state handlers
            signalRConnection.onclose(error => {
                console.log("SignalR connection closed", error);
                updateConnectionStatus('disconnected', 'Connection lost');
            });

            signalRConnection.onreconnecting(error => {
                console.log("SignalR reconnecting...", error);
                updateConnectionStatus('connecting', 'Reconnecting...');
            });

            signalRConnection.onreconnected(connectionId => {
                console.log("SignalR reconnected:", connectionId);
                updateConnectionStatus('connected', 'Reconnected');
                signalRConnection.invoke("SubscribeToCars", [currentCarId]);
            });
        }

        // Update car position on map
        function updateCarPosition(lat, lng, timestamp) {
            const newPos = [lat, lng];
            const updateTime = new Date(timestamp || Date.now());

            // Calculate speed if we have a previous position
            if (lastPosition && lastPositionTime) {
                const distance = calculateDistance(lastPosition.lat, lastPosition.lng, lat, lng);
                const timeDiff = (updateTime - lastPositionTime) / 1000 / 3600; // hours
                if (timeDiff > 0) {
                    currentSpeed = distance / timeDiff;
                }
            }

            // Update marker position
            createCarMarker(newPos, true);

            // Add to real-time path
            if (realtimePolyline) {
                realtimePolyline.addLatLng(newPos);
                realtimePositions.push({lat, lng, timestamp: updateTime});
            }

            // Update UI elements
            updateRealtimeStats(lat, lng, updateTime);

            // Store current position
            lastPosition = {lat, lng, timestamp: updateTime};
            lastPositionTime = updateTime;

            // Auto-center map occasionally
            if (Math.random() < 0.1) { // 10% chance
                map.panTo(newPos);
            }

            console.log(`Vehicle position updated: ${lat.toFixed(6)}, ${lng.toFixed(6)} at ${updateTime.toLocaleTimeString()}`);
        }

        // Update real-time statistics
        function updateRealtimeStats(lat, lng, timestamp) {
            // Update location display
            $('#currentLocation').text(`${lat.toFixed(6)}, ${lng.toFixed(6)}`);
            $('#lastUpdate').text(timestamp.toLocaleTimeString());
            $('#lastTrackedTime').text(timestamp.toLocaleString());

            // Update speed display
            $('#currentSpeed').text(currentSpeed.toFixed(1));

            // Update total distance for today
            if (realtimePositions.length > 1) {
                const todayDistance = calculateTotalDistance(realtimePositions);
                $('#totalDistance').text((totalDistanceToday + todayDistance).toFixed(1));
            }

            // Update vehicle status
            const timeSinceUpdate = Date.now() - timestamp.getTime();
            if (timeSinceUpdate < 60000) { // Less than 1 minute
                $('#vehicleStatus').text('Active').removeClass('text-warning text-danger').addClass('text-success');
            } else if (timeSinceUpdate < 300000) { // Less than 5 minutes
                $('#vehicleStatus').text('Delayed').removeClass('text-success text-danger').addClass('text-warning');
            } else {
                $('#vehicleStatus').text('Inactive').removeClass('text-success text-warning').addClass('text-danger');
            }
        }

        // Calculate distance between two points (Haversine formula)
        function calculateDistance(lat1, lon1, lat2, lon2) {
            const R = 6371; // Earth's radius in kilometers
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
                      Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            return R * c;
        }

        // Calculate total distance from array of positions
          function calculateTotalDistance(positions) {
              if (positions.length < 2) return 0;

              let totalDistance = 0;
              for (let i = 1; i < positions.length; i++) {
                  totalDistance += calculateDistance(
                      positions[i-1].lat, positions[i-1].lng,
                      positions[i].lat, positions[i].lng
                  );
              }
              return totalDistance;
          }

          // Calculate daily distance from location history
          function calculateDailyDistance(locations) {
              if (!locations || locations.length < 2) {
                  totalDistanceToday = 0;
                  return;
              }

              const today = new Date().toDateString();
              const todayLocations = locations.filter(loc =>
                  new Date(loc.timestamp).toDateString() === today
              );

              totalDistanceToday = calculateTotalDistance(todayLocations.map(loc => ({
                  lat: loc.latitude,
                  lng: loc.longitude
              })));

              $('#totalDistance').text(totalDistanceToday.toFixed(1));
          }

          // Update connection status indicator
          function updateConnectionStatus(status, message) {
              const statusElement = $('#connectionStatus');
              statusElement.removeClass('connection-connected connection-disconnected connection-connecting');

              switch (status) {
                  case 'connected':
                      statusElement.addClass('connection-connected');
                      statusElement.html('<i class="fas fa-wifi me-2"></i>' + message);
                      break;
                  case 'disconnected':
                      statusElement.addClass('connection-disconnected');
                      statusElement.html('<i class="fas fa-wifi-slash me-2"></i>' + message);
                      break;
                  case 'connecting':
                      statusElement.addClass('connection-connecting');
                      statusElement.html('<i class="fas fa-spinner fa-spin me-2"></i>' + message);
                      break;
              }
          }

          // Show alert notification
          function showAlert(type, message, duration = 5000) {
              const alertId = 'alert-' + Date.now();
              const alertHtml = `
                  <div id="${alertId}" class="alert alert-${type} alert-dismissible fade show" role="alert">
                      <i class="fas fa-${getAlertIcon(type)} me-2"></i>
                      ${message}
                      <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                  </div>
              `;

              $('#alertContainer').append(alertHtml);

              // Auto-dismiss after duration
              setTimeout(() => {
                  $(`#${alertId}`).alert('close');
              }, duration);
          }

          // Get appropriate icon for alert type
          function getAlertIcon(type) {
              switch (type) {
                  case 'success': return 'check-circle';
                  case 'danger': return 'exclamation-circle';
                  case 'warning': return 'exclamation-triangle';
                  case 'info': return 'info-circle';
                  default: return 'info-circle';
              }
          }

          // Fetch location suggestions for routing
          async function fetchSuggestions(query, datalistId) {
              try {
                  const response = await fetch(`/Map/SearchLocations?query=${encodeURIComponent(query)}`);
                  if (!response.ok) return;

                  const suggestions = await response.json();
                  const datalist = document.getElementById(datalistId);

                  if (datalist) {
                      datalist.innerHTML = '';
                      suggestions.forEach(suggestion => {
                          const option = document.createElement('option');
                          option.value = suggestion.display_name || suggestion.name;
                          option.setAttribute('data-lat', suggestion.lat);
                          option.setAttribute('data-lon', suggestion.lon);
                          datalist.appendChild(option);
                      });
                  }
              } catch (error) {
                  console.error('Error fetching suggestions:', error);
              }
          }

          // Get route to destination
          async function getRoute() {
              const destination = $('#destination').val().trim();
              if (!destination) {
                  showAlert('warning', 'Please enter a destination');
                  return;
              }

              if (!lastPosition) {
                  showAlert('warning', 'Vehicle location not available');
                  return;
              }

              try {
                  $('#findRouteBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Finding Route...');

                  // Geocode destination if needed
                  let destLat, destLng;
                  const option = document.querySelector(`#destinationSuggestions option[value="${destination}"]`);

                  if (option) {
                      destLat = parseFloat(option.getAttribute('data-lat'));
                      destLng = parseFloat(option.getAttribute('data-lon'));
                  } else {
                      const geoResponse = await fetch(`/Map/Geocode?address=${encodeURIComponent(destination)}`);
                      if (!geoResponse.ok) throw new Error('Failed to geocode destination');

                      const geoData = await geoResponse.json();
                      if (!geoData.lat || !geoData.lon) throw new Error('Destination not found');

                      destLat = geoData.lat;
                      destLng = geoData.lon;
                  }

                  // Get route
                  const routeResponse = await fetch('/Map/GetRoute', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({
                          startLat: lastPosition.lat,
                          startLng: lastPosition.lng,
                          endLat: destLat,
                          endLng: destLng,
                          vehicleId: currentCarId
                      })
                  });

                  if (!routeResponse.ok) throw new Error('Route calculation failed');

                  const routeData = await routeResponse.json();
                  displayRoute(routeData, destLat, destLng, destination);

              } catch (error) {
                  console.error('Route error:', error);
                  showAlert('danger', `Route calculation failed: ${error.message}`);
              } finally {
                  $('#findRouteBtn').prop('disabled', false).html('<i class="fas fa-route me-1"></i>Find Route');
              }
          }

          // Display route on map
          function displayRoute(routeData, destLat, destLng, destinationName) {
              // Clear existing route
              if (routeLine) map.removeLayer(routeLine);

              // Create route polyline
              const coordinates = routeData.coordinates || routeData.geometry?.coordinates;
              if (!coordinates || coordinates.length === 0) {
                  showAlert('warning', 'No route coordinates received');
                  return;
              }

              // Convert coordinates (may need to swap lat/lng depending on API)
              const routePoints = coordinates.map(coord =>
                  Array.isArray(coord) ? [coord[1], coord[0]] : [coord.lat, coord.lng]
              );

              routeLine = L.polyline(routePoints, {
                  color: '#0d6efd',
                  weight: 5,
                  opacity: 0.8,
                  dashArray: '10,5'
              }).addTo(map);

              // Add destination marker
              const destMarker = L.marker([destLat, destLng], {
                  icon: L.divIcon({
                      className: 'destination-marker',
                      html: '<i class="fas fa-map-marker-alt fa-2x text-danger"></i>',
                      iconSize: [24, 24],
                      iconAnchor: [12, 24]
                  })
              }).addTo(map);

              destMarker.bindPopup(`<b>Destination</b><br>${destinationName}`);

              // Fit map to show entire route
              const bounds = L.latLngBounds([
                  [lastPosition.lat, lastPosition.lng],
                  [destLat, destLng],
                  ...routePoints
              ]);
              map.fitBounds(bounds, { padding: [20, 20] });

              // Store current route data
              currentRouteData = {
                  ...routeData,
                  destination: destinationName,
                  destinationLat: destLat,
                  destinationLng: destLng,
                  coordinates: routePoints
              };

              // Show route info and save button
              displayRouteInfo(routeData);
              $('#saveRouteBtn').show();
              showAlert('success', 'Route calculated successfully');
          }

          // Display route information
          function displayRouteInfo(routeData) {
              const distance = (routeData.distance || 0) / 1000; // Convert to km
              const duration = Math.round((routeData.duration || 0) / 60); // Convert to minutes

              const routeInfoHtml = `
                  <div class="alert alert-info mb-0">
                      <h6><i class="fas fa-route me-2"></i>Route Details</h6>
                      <div class="row g-2">
                          <div class="col-6">
                              <small class="text-muted">Distance:</small>
                              <div class="fw-bold">${distance.toFixed(1)} km</div>
                          </div>
                          <div class="col-6">
                              <small class="text-muted">Est. Time:</small>
                              <div class="fw-bold">${duration} min</div>
                          </div>
                      </div>
                  </div>
              `;

              $('#routeInfo').html(routeInfoHtml).show();

              // Update current route card
              $('#currentRouteCard').show();
              $('#currentRouteDetails').html(`
                  <div class="d-flex justify-content-between align-items-center mb-2">
                      <span class="fw-bold">To: ${currentRouteData.destination}</span>
                      <span class="badge bg-primary">${distance.toFixed(1)} km</span>
                  </div>
                  <div class="row g-2">
                      <div class="col-6">
                          <small class="text-muted">Duration:</small>
                          <div class="fw-bold">${duration} min</div>
                      </div>
                      <div class="col-6">
                          <small class="text-muted">Status:</small>
                          <div class="fw-bold text-info">Active</div>
                      </div>
                  </div>
                  <div class="mt-2">
                      <button class="btn btn-outline-danger btn-sm w-100" onclick="clearRoute()">
                          <i class="fas fa-times me-1"></i>End Navigation
                      </button>
                  </div>
              `);
          }

          // Save current route
          async function saveCurrentRoute() {
              if (!currentRouteData) {
                  showAlert('warning', 'No route to save');
                  return;
              }

              const routeName = prompt('Enter a name for this route:', currentRouteData.destination);
              if (!routeName) return;

              try {
                  $('#saveRouteBtn').prop('disabled', true).html('<i class="fas fa-spinner fa-spin me-1"></i>Saving...');

                  const response = await fetch('/Map/SaveRoute', {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({
                          name: routeName,
                          vehicleId: currentCarId,
                          startLat: lastPosition.lat,
                          startLng: lastPosition.lng,
                          endLat: currentRouteData.destinationLat,
                          endLng: currentRouteData.destinationLng,
                          distance: currentRouteData.distance,
                          duration: currentRouteData.duration,
                          routeData: JSON.stringify(currentRouteData.coordinates)
                      })
                  });

                  if (!response.ok) throw new Error('Failed to save route');

                  showAlert('success', 'Route saved successfully');
                  loadSavedRoutes(); // Refresh saved routes list

              } catch (error) {
                  console.error('Error saving route:', error);
                  showAlert('danger', `Failed to save route: ${error.message}`);
              } finally {
                  $('#saveRouteBtn').prop('disabled', false).html('<i class="fas fa-save me-1"></i>Save');
              }
          }

          // Clear current route
          function clearRoute() {
              if (routeLine) {
                  map.removeLayer(routeLine);
                  routeLine = null;
              }

              // Remove destination markers
              map.eachLayer(layer => {
                  if (layer.options && layer.options.icon &&
                      layer.options.icon.options &&
                      layer.options.icon.options.className === 'destination-marker') {
                      map.removeLayer(layer);
                  }
              });

              // Clear form and hide elements
              $('#destination').val('');
              $('#routeInfo').hide();
              $('#saveRouteBtn').hide();
              $('#currentRouteCard').hide();

              currentRouteData = null;
              showAlert('info', 'Route cleared');
          }

          // Load saved routes
          async function loadSavedRoutes() {
              try {
                  const response = await fetch(`/Map/GetSavedRoutes?vehicleId=${currentCarId}`);
                  if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                  const routes = await response.json();
                  renderSavedRoutes(routes);

              } catch (error) {
                  console.error('Error loading saved routes:', error);
                  $('#savedRoutesList').html(`
                      <div class="text-center py-3">
                          <i class="fas fa-exclamation-triangle text-warning"></i>
                          <p class="small text-muted mt-2 mb-0">Failed to load routes</p>
                      </div>
                  `);
              }
          }

          // Render saved routes list
          function renderSavedRoutes(routes) {
              if (!routes || routes.length === 0) {
                  $('#savedRoutesList').html(`
                      <div class="text-center py-3">
                          <i class="fas fa-route text-muted fa-2x mb-2"></i>
                          <p class="small text-muted mb-0">No saved routes found</p>
                      </div>
                  `);
                  return;
              }

              const routesHtml = routes.map(route => `
                  <div class="card saved-route-card mb-2" onclick="loadSavedRoute(${route.id})" data-route-id="${route.id}">
                      <div class="card-body p-2">
                          <div class="d-flex justify-content-between align-items-start">
                              <div>
                                  <h6 class="card-title mb-1">${route.name}</h6>
                                  <small class="text-muted">
                                      <i class="fas fa-road me-1"></i>${(route.distance / 1000).toFixed(1)} km
                                      <i class="fas fa-clock ms-2 me-1"></i>${Math.round(route.duration / 60)} min
                                  </small>
                              </div>
                              <div class="dropdown" onclick="event.stopPropagation()">
                                  <button class="btn btn-sm btn-outline-secondary dropdown-toggle" data-bs-toggle="dropdown">
                                      <i class="fas fa-ellipsis-v"></i>
                                  </button>
                                  <ul class="dropdown-menu">
                                      <li><a class="dropdown-item" href="#" onclick="loadSavedRoute(${route.id})">
                                          <i class="fas fa-play me-2"></i>Load Route
                                      </a></li>
                                      <li><a class="dropdown-item text-danger" href="#" onclick="deleteSavedRoute(${route.id})">
                                          <i class="fas fa-trash me-2"></i>Delete
                                      </a></li>
                                  </ul>
                              </div>
                          </div>
                          <div class="mt-2">
                              <small class="text-muted">Saved: ${new Date(route.createdAt).toLocaleDateString()}</small>
                          </div>
                      </div>
                  </div>
              `).join('');

              $('#savedRoutesList').html(routesHtml);
          }

          // Load a saved route
          async function loadSavedRoute(routeId) {
              try {
                  const response = await fetch(`/Map/GetSavedRoute?id=${routeId}`);
                  if (!response.ok) throw new Error('Failed to load route');

                  const route = await response.json();
                  const coordinates = JSON.parse(route.routeData);

                  // Clear existing route
                  clearRoute();

                  // Display the saved route
                  routeLine = L.polyline(coordinates, {
                      color: '#198754',
                      weight: 4,
                      opacity: 0.8,
                      dashArray: '8,4'
                  }).addTo(map);

                  // Add destination marker
                  const destMarker = L.marker([route.endLat, route.endLng], {
                      icon: L.divIcon({
                          className: 'destination-marker',
                          html: '<i class="fas fa-map-marker-alt fa-2x text-success"></i>',
                          iconSize: [24, 24],
                          iconAnchor: [12, 24]
                      })
                  }).addTo(map);

                  destMarker.bindPopup(`<b>Saved Route</b><br>${route.name}`);

                  // Fit map to route
                  map.fitBounds(routeLine.getBounds(), { padding: [20, 20] });

                  // Update destination field
                  $('#destination').val(route.name);

                  // Store as current route
                  currentRouteData = {
                      destination: route.name,
                      destinationLat: route.endLat,
                      destinationLng: route.endLng,
                      coordinates: coordinates,
                      distance: route.distance,
                      duration: route.duration
                  };

                  displayRouteInfo(route);
                  showAlert('success', `Loaded saved route: ${route.name}`);

              } catch (error) {
                  console.error('Error loading saved route:', error);
                  showAlert('danger', `Failed to load route: ${error.message}`);
              }
          }

          // Delete a saved route
          async function deleteSavedRoute(routeId) {
              if (!confirm('Are you sure you want to delete this route?')) return;

              try {
                  const response = await fetch(`/Map/DeleteSavedRoute?id=${routeId}`, {
                      method: 'DELETE'
                  });

                  if (!response.ok) throw new Error('Failed to delete route');

                  showAlert('success', 'Route deleted successfully');
                  loadSavedRoutes(); // Refresh list

              } catch (error) {
                  console.error('Error deleting route:', error);
                  showAlert('danger', `Failed to delete route: ${error.message}`);
              }
          }

          // Center map on vehicle
          function centerMapOnVehicle() {
              if (lastPosition) {
                  map.setView([lastPosition.lat, lastPosition.lng], 16);
                  if (carMarker) {
                      carMarker.openPopup();
                  }
              } else {
                  showAlert('warning', 'Vehicle location not available');
              }
          }

          // Toggle location history visibility
          function toggleLocationHistory() {
              if (historyPolyline) {
                  if (map.hasLayer(historyPolyline)) {
                      map.removeLayer(historyPolyline);
                      showAlert('info', 'Location history hidden');
                  } else {
                      map.addLayer(historyPolyline);
                      showAlert('info', 'Location history shown');
                  }
              }
          }

          // Start periodic updates for connection health
          function startPeriodicUpdates() {
              setInterval(() => {
                  // Check connection health
                  if (signalRConnection && signalRConnection.state === signalR.HubConnectionState.Connected) {
                      // Connection is healthy
                      updateConnectionStatus('connected', 'Real-time tracking active');
                  } else if (signalRConnection && signalRConnection.state === signalR.HubConnectionState.Reconnecting) {
                      updateConnectionStatus('connecting', 'Reconnecting...');
                  } else {
                      updateConnectionStatus('disconnected', 'Connection lost');
                      // Attempt to reconnect
                      if (signalRConnection && signalRConnection.state === signalR.HubConnectionState.Disconnected) {
                          initializeSignalRConnection();
                      }
                  }
              }, 10000); // Check every 10 seconds

              // Periodic data refresh
              setInterval(() => {
                  if (currentCarId > 0) {
                      // Refresh car details occasionally
                      fetchCarDetails();
                  }
              }, 300000); // Refresh every 5 minutes
          }

          // Handle page visibility changes
          document.addEventListener('visibilitychange', function() {
              if (document.hidden) {
                  console.log('Page hidden, maintaining connection...');
              } else {
                  console.log('Page visible, checking connection...');
                  if (signalRConnection && signalRConnection.state !== signalR.HubConnectionState.Connected) {
                      initializeSignalRConnection();
                  }
              }
          });

          // Handle window beforeunload
          window.addEventListener('beforeunload', function() {
              if (signalRConnection && signalRConnection.state === signalR.HubConnectionState.Connected) {
                  signalRConnection.stop();
              }
          });

          // Export functions for global access
          window.centerMapOnVehicle = centerMapOnVehicle;
          window.toggleLocationHistory = toggleLocationHistory;
          window.loadSavedRoute = loadSavedRoute;
          window.deleteSavedRoute = deleteSavedRoute;
    </script>
</body>
</html>