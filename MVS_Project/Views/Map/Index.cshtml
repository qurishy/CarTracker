@{
    ViewData["Title"] = "Vehicle Tracker";
    int? carId = ViewBag.CarId;
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" />
    <style>
        #map {
            height: 80vh;
            border-radius: 8px;
            min-height: 500px;
        }

        .car-marker {
            filter: hue-rotate(200deg);
            width: 30px !important;
            height: 30px !important;
        }

        .history-line {
            color: #0d6efd;
            weight: 4;
        }

        .realtime-line {
            color: #dc3545;
            weight: 3;
            dashArray: '5,5';
        }

        .route-line {
            color: #0d6efd;
            weight: 5;
            opacity: 0.8;
            dashArray: '5,5';
        }

        .card {
            margin-top: 1rem;
        }

        .spinner-border {
            display: inline-block;
            width: 2rem;
            height: 2rem;
        }

        #routeControls {
            position: absolute;
            top: 10px;
            right: 10px;
            z-index: 1000;
            background: white;
            padding: 15px;
            border-radius: 8px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            min-width: 300px;
        }

        #routeInfo {
            display: none;
            margin-top: 15px;
        }

        .route-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        }

        .saved-route-card {
            transition: transform 0.2s ease;
            cursor: pointer;
        }

            .saved-route-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            }

        .route-controls-header {
            background: #f8f9fa;
            margin: -15px -15px 15px -15px;
            padding: 10px 15px;
            border-radius: 8px 8px 0 0;
            border-bottom: 1px solid #dee2e6;
        }

        .btn-group-sm .btn {
            padding: 0.25rem 0.5rem;
            font-size: 0.875rem;
        }

        .alert-container {
            position: fixed;
            top: 20px;
            right: 20px;
            z-index: 9999;
            min-width: 300px;
        }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Car Details Panel -->
            <div class="col-md-4" id="carDetailsPanel">
                <div class="card mt-3">
                    <div class="card-header bg-primary text-white">
                        <h5 id="carHeader">Vehicle Details</h5>
                    </div>
                    <div class="card-body">
                        <div id="carDetails">
                            @if (carId.HasValue)
                            {
                                <div class="text-center">
                                    <div class="spinner-border" role="status">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <p>Loading vehicle data...</p>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted">No vehicle selected. Select a vehicle from the dashboard.</p>
                            }
                        </div>
                    </div>
                </div>

                <!-- Current Route Display Card -->
                <div class="card mt-3" id="currentRouteCard" style="display: none;">
                    <div class="card-header route-card">
                        <h6 class="mb-0">
                            <i class="fas fa-route me-2"></i>Current Route
                        </h6>
                    </div>
                    <div class="card-body" id="currentRouteDetails">
                        <!-- Current route details will be populated here -->
                    </div>
                </div>

                <!-- Saved Routes -->
                <div class="card mt-3">
                    <div class="card-header bg-success text-white">
                        <h6 class="mb-0">
                            <i class="fas fa-bookmark me-2"></i>Saved Routes
                        </h6>
                    </div>
                    <div class="card-body">
                        <div id="savedRoutesList">
                            <p class="text-muted">Loading saved routes...</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Map Container -->
            <div class="col-md-8 position-relative">
                <div id="map"></div>

                <!-- Route Controls -->
                <div id="routeControls" style="display: none;">
                    <div class="route-controls-header">
                        <h6 class="mb-0">
                            <i class="fas fa-route me-2"></i>Route Planning
                        </h6>
                    </div>

                    <div class="input-group mb-3">
                        <span class="input-group-text"><i class="fas fa-map-marker-alt"></i></span>
                        <input type="text" id="destination" class="form-control" placeholder="Enter destination..." list="destinationSuggestions">
                        <datalist id="destinationSuggestions"></datalist>
                        <button id="findRouteBtn" class="btn btn-primary">
                            <i class="fas fa-search me-1"></i>Find Route
                        </button>
                    </div>

                    <div id="routeInfo"></div>

                    <div class="d-flex gap-2 mt-3">
                        <button id="saveRouteBtn" class="btn btn-success btn-sm" style="display: none;">
                            <i class="fas fa-save me-1"></i>Save Route
                        </button>
                        <button id="clearRouteBtn" class="btn btn-danger btn-sm">
                            <i class="fas fa-times me-1"></i>Clear Route
                        </button>
                        <button id="hideRouteControlsBtn" class="btn btn-secondary btn-sm">
                            <i class="fas fa-eye-slash me-1"></i>Hide
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Alert Container -->
    <div id="alertContainer" class="alert-container"></div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@7.0.5/dist/browser/signalr.min.js"></script>

    <script>
        // Fallback if CDN fails
        if (typeof signalR === 'undefined') {
            document.write('<script src="/lib/microsoft/signalr/dist/browser/signalr.min.js"><\/script>');
        }
    </script>

    <script>
        // Global variables
        let map, carMarker, historyPolyline, realtimePolyline;
        let currentCarId = @(carId.HasValue? carId.Value: 0);
        let signalRConnection;
        let routeLine = null;
        let routeMarkers = [];
        let currentRouteData = null;
        const ORS_API_KEY = 'eyJvcmciOiI1YjNjZTM1OTc4NTExMTAwMDFjZjYyNDgiLCJpZCI6Ijc4YzU1OGVlODQyNzQ5Yzc4MmE3MDc3ZjcwZGYyMzMyIiwiaCI6Im11cm11cjY0In0=';

        $(document).ready(function () {
            initializeMap();
            initRouting();

            if (currentCarId > 0) {
                fetchCarDetails();
                loadSavedRoutes(currentCarId);
                initializeSignalRConnection();
            }
        });

        // Initialize Leaflet map
        function initializeMap() {
            map = L.map('map').setView([34.5, 69.2], 13);
            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap contributors'
            }).addTo(map);
        }

        // Fetch car details from server
        async function fetchCarDetails() {
            try {
                const response = await fetch(`/Map/GetCar?id=${currentCarId}`);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const car = await response.json();
                renderCarDetails(car);
                fetchCarLocations();
            } catch (error) {
                console.error('Failed to load car details:', error);
                $('#carDetails').html(`<div class="alert alert-danger">Error loading vehicle data: ${error.message}</div>`);
            }
        }

        // Render car details in panel
        function renderCarDetails(car) {
            const lastPos = car.lastPosition || {};
            const detailsHtml = `
                <div class="row">
                    <div class="col-12">
                        <h4>${car.make} ${car.model}</h4>
                        <hr>
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-4"><strong>License:</strong></div>
                    <div class="col-8">${car.licensePlate}</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4"><strong>Last Tracked:</strong></div>
                    <div class="col-8">${new Date(car.lastTracked).toLocaleString()}</div>
                </div>
                <div class="row mb-2">
                    <div class="col-4"><strong>Location:</strong></div>
                    <div class="col-8" id="currentLocation">${lastPos.latitude?.toFixed(4)}, ${lastPos.longitude?.toFixed(4)}</div>
                </div>
                <div class="row mb-3">
                    <div class="col-4"><strong>Total Points:</strong></div>
                    <div class="col-8">${car.totalLocations}</div>
                </div>
                <div class="d-grid">
                    <button id="showRouteBtn" class="btn btn-primary">
                        <i class="fas fa-route me-2"></i>Plan New Route
                    </button>
                </div>
            `;
            $('#carDetails').html(detailsHtml);
            $('#carHeader').text(`${car.licensePlate} - ${car.make} ${car.model}`);

            // Add event listener for route button
            $('#showRouteBtn').click(function() {
                $('#routeControls').show();
            });
        }

        // Fetch location history from server
        async function fetchCarLocations() {
            try {
                const response = await fetch(`/Map/GetCarLocations?vehicleId=${currentCarId}`);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const locations = await response.json();
                plotLocationHistory(locations);
            } catch (error) {
                console.error('Error loading location history:', error);
                showAlert('danger', `Failed to load travel history: ${error.message}`);
            }
        }

        // Plot location history on map
        function plotLocationHistory(locations) {
            // Clear existing layers
            if (historyPolyline) map.removeLayer(historyPolyline);
            if (realtimePolyline) map.removeLayer(realtimePolyline);
            if (carMarker) map.removeLayer(carMarker);

            // Convert to LatLng objects
            const points = locations.map(loc => [loc.latitude, loc.longitude]);

            // Create marker for latest position
            if (points.length > 0) {
                const lastPoint = points[0];
                carMarker = L.marker(lastPoint, {
                    icon: L.divIcon({
                        className: 'car-marker',
                        html: '<i class="fa-solid fa-car fa-2x"></i>',
                        iconSize: [30, 30]
                    })
                }).addTo(map);

                // Center map on vehicle
                map.setView(lastPoint, 15);
            }

            // Create empty real-time polyline
            realtimePolyline = L.polyline([], {
                color: '#dc3545',
                weight: 3,
                dashArray: '5,5'
            }).addTo(map);
        }

        // Initialize SignalR connection
        function initializeSignalRConnection() {
            // Wait until SignalR is fully loaded
            if (typeof signalR === 'undefined' || typeof signalR.HubConnectionBuilder === 'undefined') {
                console.log("Waiting for SignalR library to load...");
                setTimeout(initializeSignalRConnection, 1000);
                return;
            }

            console.log("Initializing SignalR connection...");

            // Build connection
            signalRConnection = new signalR.HubConnectionBuilder()
                .withUrl("/trackingHub")
                .configureLogging(signalR.LogLevel.Information)
                .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                .build();

            // Setup handlers
            signalRConnection.on("ReceiveCarUpdate", (carId, lat, lng) => {
                console.log("Received position update for car:", carId);
                if (carId === currentCarId) {
                    updateCarPosition(lat, lng);
                }
            });

            // Start connection
            signalRConnection.start()
                .then(() => {
                    console.log("SignalR connected. Subscribing to car updates...");
                    return signalRConnection.invoke("SubscribeToCars", [currentCarId]);
                })
                .then(() => {
                    console.log("Successfully subscribed to car updates");
                })
                .catch(err => {
                    console.error("SignalR connection error:", err);
                    setTimeout(initializeSignalRConnection, 5000);
                });

            // Connection state handlers
            signalRConnection.onclose(error => {
                console.log("SignalR connection closed", error);
            });

            signalRConnection.onreconnecting(error => {
                console.log("SignalR reconnecting...", error);
            });

            signalRConnection.onreconnected(connectionId => {
                console.log("SignalR reconnected. New connection ID:", connectionId);
                signalRConnection.invoke("SubscribeToCars", [currentCarId]);
            });
        }

        // Update car position on map
        function updateCarPosition(lat, lng) {
            const newPos = [lat, lng];

            // Update marker position
            if (carMarker) {
                carMarker.setLatLng(newPos);
            } else {
                carMarker = L.marker(newPos, {
                    icon: L.divIcon({
                        className: 'car-marker',
                        html: '<i class="fa-solid fa-car fa-2x"></i>',
                        iconSize: [30, 30]
                    })
                }).addTo(map);
            }

            // Add to real-time path
            realtimePolyline.addLatLng(newPos);

            // Update UI
            $('#currentLocation').text(`${lat.toFixed(4)}, ${lng.toFixed(4)}`);

            // Center map if needed
            map.setView(newPos, map.getZoom());
        }

        // Initialize routing functionality
        function initRouting() {
            const destinationInput = document.getElementById('destination');

            if (destinationInput) {
                destinationInput.addEventListener('input', function () {
                    fetchSuggestions(this.value, 'destinationSuggestions');
                });

                // Event listeners
                $('#findRouteBtn').click(getRoute);
                $('#saveRouteBtn').click(saveCurrentRoute);
                $('#clearRouteBtn').click(clearRoute);
                $('#hideRouteControlsBtn').click(() => $('#routeControls').hide());
            }
        }

        // Fetch autocomplete suggestions
        function fetchSuggestions(query, datalistId) {
            if (!query || query.length < 3) return;

            fetch(`/Map/GeocodeAutocomplete?query=${encodeURIComponent(query)}&country=AF`)
                .then(res => res.json())
                .then(data => {
                    const list = document.getElementById(datalistId);
                    list.innerHTML = '';
                    if (data.features) {
                        data.features.forEach(feature => {
                            const option = document.createElement('option');
                            option.value = feature.properties.label;
                            list.appendChild(option);
                        });
                    }
                })
                .catch(err => {
                    console.error('Autocomplete error:', err);
                    showAlert('danger', 'Failed to fetch location suggestions');
                });
        }

        // Get route between current car position and destination
              // Get route between current car position and destination
        async function getRoute() {
            const destination = document.getElementById("destination").value;

            if (!destination) {
                showAlert("warning", "Please enter a destination");
                return;
            }

            try {
                console.log("Starting route calculation...");

                // Show loading state
                const routeInfo = document.getElementById('routeInfo');
                routeInfo.style.display = 'block';
                routeInfo.innerHTML = '<div class="text-center"><div class="spinner-border spinner-border-sm" role="status"></div> Calculating route...</div>';

                // Get current car position
                if (!carMarker) {
                    throw new Error('Cannot determine current vehicle position');
                }
                const fromCoord = carMarker.getLatLng();
                console.log("From coordinate:", fromCoord);

                // Geocode destination using our server-side proxy
                console.log("Geocoding destination:", destination);
                const toGeoResponse = await fetch(`/Map/GeocodeSearch?query=${encodeURIComponent(destination)}&country=AF`);

                if (!toGeoResponse.ok) {
                    const errorText = await toGeoResponse.text();
                    console.error("Geocoding failed:", toGeoResponse.status, errorText);
                    throw new Error(`Geocoding failed: ${toGeoResponse.status} - ${errorText}`);
                }

                const toGeo = await toGeoResponse.json();
                console.log("Geocoding response:", toGeo);

                if (!toGeo.features || !toGeo.features.length) {
                    throw new Error('Could not find location for destination');
                }

                const toCoord = toGeo.features[0].geometry.coordinates;
                console.log("To coordinate:", toCoord);

                // Get route using our server-side proxy
                const directionsRequest = {
                    coordinates: [
                        [fromCoord.lng, fromCoord.lat], // Current position
                        toCoord // Destination
                    ]
                };

                console.log("Directions request:", directionsRequest);

                const routeResponse = await fetch('/Map/GetDirections', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(directionsRequest)
                });

                console.log("Route response status:", routeResponse.status);

                if (!routeResponse.ok) {
                    let errorMessage = `HTTP error! status: ${routeResponse.status}`;
                    let errorDetails = '';

                    try {
                        const errorData = await routeResponse.json();
                        console.error("Route error data:", errorData);
                        errorMessage = errorData.error || errorMessage;
                        errorDetails = errorData.details || '';
                    } catch (e) {
                        // If response is not JSON, try to get text
                        try {
                            errorDetails = await routeResponse.text();
                            console.error("Route error text:", errorDetails);
                        } catch (textError) {
                            console.error("Could not parse error response:", textError);
                            errorDetails = routeResponse.statusText || '';
                        }
                    }

                    throw new Error(`${errorMessage}${errorDetails ? ': ' + errorDetails : ''}`);
                }

                const route = await routeResponse.json();
                console.log("Route response:", route);

                if (!route.features || !route.features.length) {
                    throw new Error('No route features returned');
                }

                const summary = route.features[0].properties.summary;
                const distanceKm = (summary.distance / 1000).toFixed(2);
                const durationMin = (summary.duration / 60).toFixed(1);

                console.log("Route summary:", { distanceKm, durationMin });

                // Store current route data for saving
                currentRouteData = {
                    destination: destination,
                    fromCoord: fromCoord,
                    toCoord: toCoord,
                    distanceKm: distanceKm,
                    durationMin: durationMin,
                    waypoints: extractWaypointsFromRoute(route.features[0].geometry),
                    routeGeometry: route.features[0].geometry
                };

                // Display route
                displayRouteOnMap(route, destination, distanceKm, durationMin);

                // Show save button
                $('#saveRouteBtn').show();

                console.log("Route calculation completed successfully");

            } catch (error) {
                console.error('Error in route calculation:', error);
                const routeInfo = document.getElementById('routeInfo');
                routeInfo.innerHTML = `<div class="alert alert-danger">
                    <strong>Error calculating route:</strong><br>
                    ${error.message}
                    <br><small class="text-muted">Check browser console for more details</small>
                </div>`;
                clearRoute();

                // Show detailed error in alert
                showAlert('danger', `Route calculation failed: ${error.message}`);
            }
        }

        // Display route on map and in current route card
        function displayRouteOnMap(route, destination, distanceKm, durationMin) {
            // Remove old route if exists
            if (routeLine) {
                map.removeLayer(routeLine);
            }

            // Draw new polyline
            routeLine = L.geoJSON(route, {
                style: {
                    color: '#0d6efd',
                    weight: 5,
                    opacity: 0.8,
                    dashArray: '5, 5'
                }
            }).addTo(map);

            // Add destination marker
            const toCoord = currentRouteData.toCoord;
            const endIcon = L.divIcon({
                className: 'custom-icon',
                html: '<i class="fas fa-map-marker-alt text-danger fa-2x"></i>',
                iconSize: [30, 30],
                iconAnchor: [15, 30]
            });

            if (window.routeEndMarker) map.removeLayer(window.routeEndMarker);
            window.routeEndMarker = L.marker([toCoord[1], toCoord[0]], { icon: endIcon })
                .addTo(map)
                .bindPopup(`<b>Destination</b><br>${destination}`);

            // Fit map to route
            map.fitBounds(routeLine.getBounds());

            // Format duration
            function formatDuration(mins) {
                const hours = Math.floor(mins / 60);
                const minutes = Math.round(mins % 60);
                return `${hours > 0 ? hours + ' hr ' : ''}${minutes} min`;
            }

            // Update route info in controls
            const routeInfo = document.getElementById('routeInfo');
            routeInfo.innerHTML = `
                <div class="route-info">
                    <h6>Route Information</h6>
                    <p><i class="fas fa-arrows-alt-h"></i> <strong>Distance:</strong> ${distanceKm} km</p>
                    <p><i class="fas fa-clock"></i> <strong>Duration:</strong> ${formatDuration(durationMin)}</p>
                    <p><i class="fas fa-map-marker-alt"></i> <strong>To:</strong> ${destination}</p>
                </div>
            `;

            // Show current route card
            displayCurrentRouteCard(destination, distanceKm, durationMin);
        }

        // Display current route in the card
        function displayCurrentRouteCard(destination, distanceKm, durationMin) {
            const routeCardHtml = `
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="mb-2">
                            <i class="fas fa-map-marker-alt text-primary me-2"></i>
                            Route to ${destination}
                        </h6>
                        <div class="row g-2">
                            <div class="col-6">
                                <small class="text-muted">Distance</small>
                                <div class="fw-bold">${distanceKm} km</div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Duration</small>
                                <div class="fw-bold">${Math.round(durationMin)} min</div>
                            </div>
                        </div>
                    </div>
                    <div class="btn-group-vertical btn-group-sm">
                        <button class="btn btn-outline-success btn-sm" onclick="saveCurrentRoute()">
                            <i class="fas fa-save"></i>
                        </button>
                        <button class="btn btn-outline-danger btn-sm" onclick="clearRoute()">
                            <i class="fas fa-times"></i>
                        </button>
                    </div>
                </div>
            `;

            $('#currentRouteDetails').html(routeCardHtml);
            $('#currentRouteCard').show();
        }

        // Extract waypoints from route geometry
        function extractWaypointsFromRoute(geometry) {
            const waypoints = [];

            if (geometry.type === 'LineString') {
                const coordinates = geometry.coordinates;
                const sampleRate = Math.max(1, Math.floor(coordinates.length / 20));

                coordinates.forEach((coord, index) => {
                    if (index % sampleRate === 0 || index === coordinates.length - 1) {
                        waypoints.push({
                            latitude: coord[1],
                            longitude: coord[0],
                            order: waypoints.length
                        });
                    }
                });
            }

            return waypoints;
        }

        // Save current route to database
        async function saveCurrentRoute() {
            if (!currentRouteData) {
                showAlert('warning', 'No route to save');
                return;
            }

            try {
                $('#saveRouteBtn').html('<i class="fas fa-spinner fa-spin me-1"></i>Saving...');

                const routeData = {
                    name: `Route to ${currentRouteData.destination}`,
                    carId: currentCarId,
                    totalDistanceKm: parseFloat(currentRouteData.distanceKm),
                    estimatedTimeMinutes: parseFloat(currentRouteData.durationMin),
                    waypoints: currentRouteData.waypoints
                };

                const response = await fetch('/Map/SaveRoute', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Accept': 'application/json'
                    },
                    body: JSON.stringify(routeData)
                });

                if (!response.ok) {
                    let errorMessage = `HTTP error! status: ${response.status}`;
                    try {
                        const errorData = await response.json();
                        errorMessage = errorData.message || errorMessage;
                    } catch (e) {
                        errorMessage = response.statusText || errorMessage;
                    }
                    throw new Error(errorMessage);
                }

                const result = await response.json();
                showAlert('success', `Route saved successfully! (ID: ${result.routeId})`);

                // Refresh saved routes
                await loadSavedRoutes(currentCarId);

                // Reset save button
                $('#saveRouteBtn').html('<i class="fas fa-save me-1"></i>Save Route').hide();

            } catch (error) {
                console.error('Error saving route:', error);
                showAlert('danger', 'Failed to save route: ' + error.message);
                $('#saveRouteBtn').html('<i class="fas fa-save me-1"></i>Save Route');
            }
        }

        // Load saved routes
        async function loadSavedRoutes(carId) {
            try {
                const response = await fetch(`/Map/car/${carId}/routes`);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const result = await response.json();
                displaySavedRoutes(result.routes || []);
            } catch (error) {
                console.error('Error loading saved routes:', error);
                $('#savedRoutesList').html('<p class="text-danger">Failed to load saved routes</p>');
            }
        }

        // Display saved routes
        function displaySavedRoutes(routes) {
            const routesList = document.getElementById('savedRoutesList');

            if (routes.length === 0) {
                routesList.innerHTML = '<p class="text-muted">No saved routes found.</p>';
                return;
            }

            const routesHtml = routes.map(route => `
                <div class="card mb-2 saved-route-card" data-route-id="${route.id}">
                    <div class="card-body p-3">
                        <div class="d-flex justify-content-between align-items-start">
                            <div class="flex-grow-1">
                                <h6 class="card-title mb-1">${route.name}</h6>
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <small class="text-muted">Distance</small>
                                        <div class="fw-bold">${route.totalDistanceKm.toFixed(2)} km</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Duration</small>
                                        <div class="fw-bold">${Math.round(route.estimatedTimeMinutes)} min</div>
                                    </div>
                                </div>
                                <small class="text-muted">
                                    <i class="fas fa-route me-1"></i>${route.waypointCount} waypoints
                                    <br><i class="fas fa-calendar me-1"></i>${new Date(route.createdAt).toLocaleDateString()}
                                </small>
                            </div>
                            <div class="btn-group-vertical btn-group-sm ms-2">
                                <button class="btn btn-outline-primary btn-sm" onclick="displayRouteOnMapById(${route.id})" title="Show on map">
                                    <i class="fas fa-map"></i>
                                </button>
                                <button class="btn btn-outline-danger btn-sm" onclick="deleteRoute(${route.id})" title="Delete route">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            `).join('');

            routesList.innerHTML = routesHtml;
        }

        // Display saved route on map
        async function displayRouteOnMapById(routeId) {
            try {
                const response = await fetch(`/Map/route/${routeId}`);
                if (!response.ok) throw new Error(`HTTP error! status: ${response.status}`);

                const result = await response.json();
                const route = result.route;

                // Clear existing route
                clearRoute();

                // Create waypoint coordinates for the polyline
                const waypoints = route.waypoints.map(wp => [wp.latitude, wp.longitude]);

                if (waypoints.length > 0) {
                    // Draw route line
                    routeLine = L.polyline(waypoints, {
                        color: '#28a745',
                        weight: 4,
                        opacity: 0.8,
                        dashArray: '10, 5'
                    }).addTo(map);

                    // Add markers for start and end points
                    if (waypoints.length >= 2) {
                        const startPoint = waypoints[0];
                        const endPoint = waypoints[waypoints.length - 1];

                        // Start marker
                        L.marker(startPoint, {
                            icon: L.divIcon({
                                className: 'custom-icon',
                                html: '<i class="fas fa-play-circle text-success fa-2x"></i>',
                                iconSize: [30, 30],
                                iconAnchor: [15, 15]
                            })
                        }).addTo(map).bindPopup(`<b>Start</b><br>${route.name}`);

                        // End marker
                        window.routeEndMarker = L.marker(endPoint, {
                            icon: L.divIcon({
                                className: 'custom-icon',
                                html: '<i class="fas fa-flag-checkered text-danger fa-2x"></i>',
                                iconSize: [30, 30],
                                iconAnchor: [15, 30]
                            })
                        }).addTo(map).bindPopup(`<b>Destination</b><br>${route.name}`);
                    }

                    // Fit map to route
                    map.fitBounds(routeLine.getBounds());

                    // Show current route card for saved route
                    const routeCardHtml = `
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <h6 class="mb-2">
                                    <i class="fas fa-bookmark text-success me-2"></i>
                                    ${route.name}
                                </h6>
                                <div class="row g-2 mb-2">
                                    <div class="col-6">
                                        <small class="text-muted">Distance</small>
                                        <div class="fw-bold">${route.totalDistanceKm.toFixed(2)} km</div>
                                    </div>
                                    <div class="col-6">
                                        <small class="text-muted">Duration</small>
                                        <div class="fw-bold">${Math.round(route.estimatedTimeMinutes)} min</div>
                                    </div>
                                </div>
                                <small class="text-muted">
                                    <i class="fas fa-route me-1"></i>${route.waypoints.length} waypoints
                                    <br><i class="fas fa-calendar me-1"></i>Created: ${new Date(route.createdAt).toLocaleDateString()}
                                </small>
                            </div>
                            <div class="btn-group-vertical btn-group-sm">
                                <button class="btn btn-outline-danger btn-sm" onclick="clearRoute()">
                                    <i class="fas fa-times"></i>
                                </button>
                                <button class="btn btn-outline-warning btn-sm" onclick="deleteRoute(${route.id})">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                    `;

                    $('#currentRouteDetails').html(routeCardHtml);
                    $('#currentRouteCard').show();

                    showAlert('success', `Displaying saved route: ${route.name}`);
                }

            } catch (error) {
                console.error('Error displaying route on map:', error);
                showAlert('danger', 'Failed to display route: ' + error.message);
            }
        }

        // Delete a saved route
        async function deleteRoute(routeId) {
            if (!confirm('Are you sure you want to delete this route?')) {
                return;
            }

            try {
                const response = await fetch(`/Map/route/${routeId}`, {
                    method: 'DELETE',
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const result = await response.json();

                if (result.success) {
                    showAlert('success', 'Route deleted successfully');
                    await loadSavedRoutes(currentCarId);
                    clearRoute();
                } else {
                    throw new Error(result.message || 'Failed to delete route');
                }

            } catch (error) {
                console.error('Error deleting route:', error);
                showAlert('danger', 'Failed to delete route: ' + error.message);
            }
        }

        // Clear route from map and UI
        function clearRoute() {
            // Remove the route line if it exists
            if (routeLine) {
                map.removeLayer(routeLine);
                routeLine = null;
            }

            // Remove destination marker if it exists
            if (window.routeEndMarker) {
                map.removeLayer(window.routeEndMarker);
                window.routeEndMarker = null;
            }

            // Clear inputs and info
            document.getElementById('destination').value = '';
            document.getElementById('routeInfo').style.display = 'none';
            document.getElementById('routeInfo').innerHTML = '';

            // Hide current route card
            $('#currentRouteCard').hide();
            $('#saveRouteBtn').hide();

            // Clear current route data
            currentRouteData = null;
        }

        // Enhanced alert function
        function showAlert(type, message) {
            const alertContainer = document.getElementById('alertContainer');
            const alertId = 'alert_' + Date.now();

            const iconClass = {
                'success': 'fa-check-circle',
                'danger': 'fa-exclamation-circle',
                'warning': 'fa-exclamation-triangle',
                'info': 'fa-info-circle'
            }[type] || 'fa-info-circle';

            const alertHtml = `
                <div id="${alertId}" class="alert alert-${type} alert-dismissible fade show" role="alert" style="margin-bottom: 10px;">
                    <i class="fas ${iconClass} me-2"></i>
                    ${message}
                    <button type="button" class="btn-close" onclick="document.getElementById('${alertId}').remove()"></button>
                </div>
            `;

            alertContainer.insertAdjacentHTML('afterbegin', alertHtml);

            // Auto-remove after 5 seconds
            setTimeout(() => {
                const alertElement = document.getElementById(alertId);
                if (alertElement) {
                    alertElement.remove();
                }
            }, 5000);
        }
    </script>
</body>
</html>