<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MVS_Project</title>
    <!-- Add to your HTML head -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MVS_Project.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />

    <style>
    body {
        position: relative;
        background: url('/images/map2.webp') no-repeat center center fixed;
        background-size: cover;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        margin: 0;
    }

    /* Dark overlay */
    body::before {
        content: "";
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.4); /* Adjust opacity here */
        z-index: -1;
    }

    main {
        flex: 1;
        z-index: 1;
    }
</style>

</head>

<body>
    <header>
       <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
    <div class="container-fluid">
        <!-- Brand -->
        <a class="navbar-brand fw-bold text-primary" asp-area="" asp-controller="" asp-action="">VTS</a>

        <!-- Navbar toggle for mobile -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Navbar content -->
        <div class="collapse navbar-collapse justify-content" id="navbarNav">
            <div class="d-flex gap-2">
                <a class="btn btn-outline-success" asp-area="" asp-controller="Map" asp-action="Dashboard">
                    <i class="fas fa-tachometer-alt me-1"></i> Dashboard
                </a>
                <a class="btn btn-sm btn-outline-secondary" asp-area="" asp-controller="Cars" asp-action="Index">
                    <i class="fas fa-car me-1"></i> Vehicle Tracking
                </a>
            </div>
        </div>
    </div>
</nav>


    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

     <footer class="bg-dark text-white text-center py-2 mt-auto">
        <small>
            &copy; @DateTime.Now.Year Bayat Power - Vehicle Tracking System | Developed by Farhad & Arshad Qurishy
        </small>
    </footer>
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
@*     <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script> *@
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@7.0.5/dist/browser/signalr.min.js"></script>
   
    <script>
        // Fallback if CDN fails
        if (typeof signalR === 'undefined') {
            document.write('<script src="/lib/microsoft/signalr/dist/browser/signalr.min.js"><\/script>');
        }
    </script>
   
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script src="~/js/Dashboard.js?v=@DateTime.UtcNow.Ticks"></script>
    <script src="~/js/index.js?v=@DateTime.UtcNow.Ticks"></script>

    <script src="~/js/map.js?v=@DateTime.UtcNow.Ticks"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
